# Claude 1M Context Engine Configuration
# Copy to .env and fill in your values

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model selection (claude-sonnet-4-6, claude-opus-4-7)
CLAUDE_MODEL=claude-sonnet-4-6

# Maximum context tokens to use (90% of 1M = 900K)
MAX_CONTEXT_TOKENS=900000

# Server settings
PORT=3721
HOST=127.0.0.1

# Cache directories
CACHE_DIR=./data/cache
VECTOR_CACHE_DIR=./data/vector-cache

# Optional: API token for remote access protection
LOCAL_API_TOKEN=
